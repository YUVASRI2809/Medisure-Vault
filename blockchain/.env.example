# ─────────────────────────────────────────────────────────────────────────────
# MediSure Vault — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask environment: development | production | testing
FLASK_ENV=production

# Secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://medisure_user:strongpassword@localhost:5432/medisure_vault

# Default admin credentials (used only by init_db.py on first run)
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@medisure.local

# Dev server only (ignored by gunicorn)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
